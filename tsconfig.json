{
  "compilerOptions": {
    "target": "es2022",
    /* Alterado para nodenext para funcionar perfeitamente com Node.js moderno */
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictPropertyInitialization": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    /* Garante que o TS vai mapear os tipos globais do Node (como 'process') */
    "types": ["node"],
    "typeRoots": ["./node_modules/@types", "./src/@types"],
    "lib": ["es2022"]
  },
  "ts-node": {
    "files": true
  }
}
